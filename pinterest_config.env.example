# Pinterest Pin CSV Generator — Configuration
# Copy this file to pinterest_config.env and fill in your own values.
#
#   cp pinterest_config.env.example pinterest_config.env
#
# Never commit pinterest_config.env — it contains your account-specific IDs.

# ── Google Sheets ────────────────────────────────────────────────────────────
# Your task sheet ID — taken from the sheet URL:
# https://docs.google.com/spreadsheets/d/SHEET_ID/edit
PINTEREST_SHEET_ID=your_sheet_id_here

# ── Google Drive ─────────────────────────────────────────────────────────────
# The Drive folder ID where generated CSVs will be uploaded — from the folder URL:
# https://drive.google.com/drive/folders/FOLDER_ID
PINTEREST_DRIVE_FOLDER_ID=your_drive_folder_id_here

# ── Scripts path ─────────────────────────────────────────────────────────────
# Absolute path to the scripts/ directory inside this repo.
# Example (Mac/Linux): /home/alice/agent-factory/scripts
#                      /Users/bob/Projects/agent-factory/scripts
PINTEREST_SCRIPTS_DIR=/path/to/agent-factory/scripts
